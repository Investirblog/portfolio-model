# ============================================================
# .env.example — Copier en .env et remplir les valeurs
# NE JAMAIS committer le .env réel sur GitHub
# ============================================================

# PostgreSQL (Railway génère cette URL automatiquement)
DATABASE_URL=postgresql://user:password@host:5432/portfolio_db

# JWT — générer avec : openssl rand -hex 32
SECRET_KEY=remplacer_par_une_cle_secrete_longue_et_aleatoire

# Brevo (emails) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=votre_cle_api_brevo

# App
ENVIRONMENT=production
ALLOWED_ORIGINS=https://investir.blog,https://portfolio.investir.blog
